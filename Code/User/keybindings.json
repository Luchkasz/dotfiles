// Coloque as suas associações de teclas neste arquivo para substituir os padrõesauto[]
[
	{
		"key": "ctrl+shift+tab",
		"command": "workbench.action.previousEditor"
	},
	{
		"key": "ctrl+tab",
		"command": "workbench.action.nextEditor"
	},
	{
		"key": "ctrl+shift+f",
		"command": "prettier.forceFormatDocument"
	}
]